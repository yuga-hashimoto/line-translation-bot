{
  "name": "line-translation-bot",
  "version": "1.0.0",
  "description": "LINE multi-language translation bot with selectable OpenAI or OpenRouter support and DeepL fallback",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "test": "node --test test/*.test.js",
    "test:openai": "AI_PROVIDER=openai node scripts/test-openai-translation.js",
    "deploy": "gcloud functions deploy lineTranslationBot --runtime nodejs20 --trigger-http --allow-unauthenticated --set-env-vars LINE_CHANNEL_ACCESS_TOKEN=$LINE_CHANNEL_ACCESS_TOKEN,LINE_CHANNEL_SECRET=$LINE_CHANNEL_SECRET,DEEPL_API_KEY=$DEEPL_API_KEY,AI_PROVIDER=${AI_PROVIDER:-openrouter},OPENAI_API_KEY=$OPENAI_API_KEY,OPENAI_MODEL=${OPENAI_MODEL:-gpt-5.6-luna},OPENROUTER_API_KEY=$OPENROUTER_API_KEY,OPENROUTER_MODEL=${OPENROUTER_MODEL:-google/gemini-2.5-flash-lite},OPENROUTER_MODEL2=$OPENROUTER_MODEL2,OPENROUTER_MODEL3=$OPENROUTER_MODEL3"
  },
  "dependencies": {
    "@line/bot-sdk": "^9.9.0",
    "@upstash/redis": "^1.34.0",
    "axios": "^1.7.0",
    "express": "^4.18.0",
    "franc": "^6.2.0",
    "languagedetect": "^2.0.0",
    "openai": "^4.77.0"
  },
  "engines": {
    "node": ">=18"
  }
}
